# =========================================
#  Feather Engine — .gitignore
# =========================================

# Dependencies
node_modules/

# Build output
dist/

# Vite
*.local

# Editor / IDE
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*~

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
.DS_Store?

# Logs
logs/
*.log
npm-debug.log*

# Environment
.env
.env.*
!.env.example

# TypeScript cache
*.tsbuildinfo

# Tauri build output (handled by src-tauri/.gitignore)
src-tauri/target/
src-tauri/gen/schemas/

# Project files created by the engine (user data)
# These are saved to user-chosen folders, not in the repo
