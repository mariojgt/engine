Three.js Import Implementation
GLTF/GLB Import (Recommended):
javascriptimport { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';

const loader = new GLTFLoader();

loader.load('assets/meshes/Character.glb', (gltf) => {
  const scene = gltf.scene;
  const animations = gltf.animations;

  // Extract mesh
  const mesh = scene.children[0];

  // Extract skeleton (if skeletal mesh)
  const skinnedMesh = mesh.isSkinnedMesh ? mesh : null;
  const skeleton = skinnedMesh ? skinnedMesh.skeleton : null;

  // Extract materials
  const materials = [];
  scene.traverse((child) => {
    if (child.isMesh && child.material) {
      materials.push(child.material);
    }
  });

  // Extract textures
  const textures = [];
  materials.forEach(material => {
    if (material.map) textures.push(material.map);
    if (material.normalMap) textures.push(material.normalMap);
    if (material.roughnessMap) textures.push(material.roughnessMap);
    // ... other maps
  });

  // Create animation mixer (if animations exist)
  if (animations.length > 0) {
    const mixer = new THREE.AnimationMixer(scene);
    animations.forEach(clip => {
      const action = mixer.clipAction(clip);
      // Store animation for later use
    });
  }

  // Save assets to project
  saveAssets({
    mesh: mesh,
    skeleton: skeleton,
    animations: animations,
    materials: materials,
    textures: textures
  });
});
